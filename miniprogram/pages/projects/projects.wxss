.pg { background: #F7F6F2; min-height: 100vh; padding-bottom: 120rpx; }
.serif { font-family: Georgia, 'Times New Roman', 'Songti SC', serif; font-weight: 600; letter-spacing: -0.02em; }

.header { padding: 48rpx 32rpx 24rpx; }
.title-xl { font-size: 48rpx; color: #1A1A1A; }

.search-bar { margin: 0 32rpx 24rpx; background: #EFEEE9; border-radius: 999px; padding: 20rpx 32rpx; display: flex; align-items: center; gap: 12rpx; }
.search-icon { font-size: 28rpx; }
.search-input { flex: 1; font-size: 28rpx; color: #1A1A1A; }
.placeholder { color: #8A8A8A; }
.search-cancel { font-size: 26rpx; color: #5A6B3A; font-weight: 600; flex-shrink: 0; }

.suggestions { background: #fff; border-radius: 24rpx; padding: 24rpx; margin: 0 32rpx 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08); }
.sg-label { font-size: 22rpx; color: #8A8A8A; font-weight: 600; padding: 8rpx 8rpx 12rpx; display: block; }
.sg-item { font-size: 28rpx; color: #1A1A1A; padding: 16rpx 8rpx; display: block; }
.sg-tags { display: flex; flex-wrap: wrap; gap: 10rpx; padding: 8rpx; }
.tag-chip { background: #F7F6F2; color: #4A4A4A; padding: 8rpx 20rpx; border-radius: 999px; font-size: 22rpx; font-weight: 500; }

.tabs { display: flex; gap: 32rpx; padding: 0 32rpx; margin-bottom: 24rpx; border-bottom: 1rpx solid #EFEEE9; }
.tab { padding-bottom: 16rpx; font-size: 30rpx; color: #8A8A8A; position: relative; }
.tab.active { color: #1A1A1A; font-weight: 600; }
.tab.active::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3rpx; background: #1A1A1A; border-radius: 3rpx; }

.chips { white-space: nowrap; padding: 0 32rpx 24rpx; }
.chip { display: inline-block; padding: 12rpx 32rpx; border-radius: 999px; font-size: 26rpx; margin-right: 16rpx; background: #EFEEE9; color: #4A4A4A; transition: all 0.15s; }
.chip.active { background: #1A1A1A; color: #fff; }

.sort-row { display: flex; gap: 16rpx; padding: 0 32rpx 24rpx; }
.pill-btn { display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; font-size: 24rpx; font-weight: 600; padding: 10rpx 28rpx; }
.pill-btn.primary { background: #5A6B3A; color: #fff; }
.pill-btn.ghost { background: #EFEEE9; color: #1A1A1A; }

.section { padding: 0 32rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 160rpx 48rpx; }
.empty-state-icon { font-size: 96rpx; margin-bottom: 24rpx; }
.empty-state-text { font-size: 32rpx; color: #1A1A1A; font-weight: 600; margin-bottom: 12rpx; }
.empty-state-sub { font-size: 26rpx; color: #8A8A8A; }

.pagination { display: flex; align-items: center; justify-content: center; gap: 24rpx; margin-top: 32rpx; }
.page-btn { padding: 16rpx 32rpx; border-radius: 999px; font-size: 26rpx; background: #fff; color: #1A1A1A; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.page-info { font-size: 26rpx; color: #6B6B6B; }
