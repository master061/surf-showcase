<view class="detail-wrap" wx:if="{{!loading}}">
  <view class="detail-header"><text class="detail-thumb">🔬</text></view>
  <view class="detail-body">
    <view class="detail-main">
      <view class="badges-row">
        <text class="{{project.status==='RECRUITING'?'badge badge-recruit':'badge badge-done'}}">{{project.status==='RECRUITING'?'🔍 招人中':'✅ 已完成'}}</text>
        <text class="badge badge-blue">{{project.field}}</text>
        <text class="badge badge-gray" wx:if="{{project.year}}">{{project.year}}</text>
        <text class="badge badge-green">{{typeLabels[project.type]||project.type}}</text>
      </view>
      <text class="detail-title">{{project.title}}</text>
      <view class="author-row">
        <text class="author-avatar">{{project.studentName?project.studentName[0]:'?'}}</text>
        <view class="author-info"><text class="author-name">{{project.studentName}}</text><text class="author-school">{{project.institution}}</text></view>
        <view class="vote-box"><text class="vote-num">{{voteCount}}</text><text class="vote-lbl">票</text></view>
      </view>
      <view class="recruit-banner" wx:if="{{project.status==='RECRUITING'}}"><text>🔍 <text style="font-weight:600">正在招募队友！</text> 期待你的加入</text></view>
      <view class="recruit-grid" wx:if="{{project.status==='RECRUITING'}}">
        <view class="recruit-cell" wx:if="{{project.recruitCount}}"><text class="rc-num">{{project.recruitCount}}</text><text class="rc-lbl">招募人数</text></view>
        <view class="recruit-cell" wx:if="{{project.expectedDuration}}"><text class="rc-dur">{{project.expectedDuration}}</text><text class="rc-lbl">预期周期</text></view>
      </view>
      <view class="detail-section"><text class="ds-title">📝 摘要</text><text class="ds-body">{{project.abstract}}</text></view>
      <view class="detail-section" wx:if="{{project.methodology}}"><text class="ds-title">🔬 方法论</text><text class="ds-body">{{project.methodology}}</text></view>
      <view class="detail-section" wx:if="{{project.researchMethods}}"><text class="ds-title">📊 研究方法</text><text class="ds-body">{{project.researchMethods}}</text></view>
      <view class="detail-section" wx:if="{{project.processResults}}"><text class="ds-title">📈 过程与结果</text><text class="ds-body">{{project.processResults}}</text></view>
      <view class="detail-section" wx:if="{{project.conclusion}}"><text class="ds-title">🎯 结论</text><text class="ds-body">{{project.conclusion}}</text></view>
      <view class="detail-section" wx:if="{{project.acknowledgments}}"><text class="ds-title">🙏 致谢</text><text class="ds-body">{{project.acknowledgments}}</text></view>
      <view class="detail-section" wx:if="{{project.references}}"><text class="ds-title">📚 参考文献</text><text class="ds-body">{{project.references}}</text></view>
      <view class="detail-section" wx:if="{{project.status==='RECRUITING' && project.recruitRequirements}}">
        <text class="ds-title">🎯 招募要求</text><text class="ds-body">{{project.recruitRequirements}}</text>
        <view class="contact-box" wx:if="{{project.contactInfo}}">📧 {{project.contactInfo}}</view>
      </view>
      <view class="detail-section" wx:if="{{project.status!=='RECRUITING' && project.members}}"><text class="ds-title">👥 参与成员</text><text class="ds-body">{{project.members}}</text></view>
      <view class="detail-section" wx:if="{{project.status!=='RECRUITING' && project.advisor}}"><text class="ds-title">👨‍🏫 指导老师</text><text class="ds-body">{{project.advisor}}</text></view>
      <view class="detail-section" wx:if="{{project.status!=='RECRUITING' && project.resultLinks}}"><text class="ds-title">🔗 成果链接</text><text class="ds-body link">{{project.resultLinks}}</text></view>
      <view class="detail-section" wx:if="{{tags.length>0}}">
        <text class="ds-title">🏷️ 标签</text>
        <view class="tags-row"><text class="tag" wx:for="{{tags}}" wx:key="*this">{{item}}</text></view>
      </view>
      <view class="action-row-detail">
        <view class="vote-btn {{voted?'voted':'not-voted'}}" bindtap="toggleVote">{{voted?'❤️ 已投票':'🤍 投票'}} · {{voteCount}}</view>
        <view class="contact-btn" wx:if="{{project.status==='RECRUITING'}}">✉️ 联系发起人</view>
      </view>
      <view class="owner-actions" wx:if="{{user && project.userId===user._id}}">
        <view class="owner-btn edit" bindtap="goEdit">✏️ 编辑</view>
        <view class="owner-btn delete" bindtap="deleteProject">🗑️ 删除</view>
      </view>
    </view>
  </view>
  <view style="height:20px"/>
</view>
<view wx:else><view class="skeleton" style="height:120px;margin:16px" wx:for="{{[1,2,3,4]}}" wx:key="*this"></view></view>
