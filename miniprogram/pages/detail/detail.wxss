.detail-wrap { padding: 0 0 24rpx; background: #F7F6F2; min-height: 100vh; }

.detail-hero { position: relative; width: 100%; height: 500rpx; overflow: hidden; }
.detail-img { width: 100%; height: 100%; display: block; }
.detail-thumb { width: 100%; height: 100%; background: linear-gradient(135deg, #667eea, #764ba2); line-height: 500rpx; text-align: center; font-size: 120rpx; }
.back-btn { position: absolute; top: 96rpx; left: 32rpx; width: 72rpx; height: 72rpx; background: rgba(0,0,0,0.2); backdrop-filter: blur(10px); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 40rpx; }

.detail-body { margin: -60rpx 24rpx 0; background: #fff; border-radius: 40rpx; padding: 40rpx 32rpx; position: relative; z-index: 2; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }

.badges-row { display: flex; gap: 12rpx; margin-bottom: 24rpx; flex-wrap: wrap; }
.detail-title { font-size: 40rpx; font-weight: 700; color: #1A1A1A; line-height: 1.3; margin-bottom: 28rpx; display: block; font-family: Georgia, 'Times New Roman', 'Songti SC', serif; }

.author-row { display: flex; align-items: center; gap: 20rpx; padding: 24rpx; background: #F7F6F2; border-radius: 24rpx; margin-bottom: 28rpx; }
.author-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 32rpx; font-weight: 700; }
.author-info { flex: 1; }
.author-name { font-size: 30rpx; font-weight: 600; color: #1A1A1A; display: block; }
.author-school { font-size: 24rpx; color: #8A8A8A; }
.vote-box { text-align: center; }
.vote-num { font-size: 36rpx; font-weight: 800; color: #D4A017; display: block; }
.vote-lbl { font-size: 20rpx; color: #8A8A8A; }

.recruit-banner { background: #FFF8E1; border: 1rpx solid #F5E6B8; border-radius: 20rpx; padding: 24rpx; margin-bottom: 28rpx; font-size: 26rpx; color: #92400E; }
.recruit-grid { display: flex; gap: 20rpx; margin-bottom: 28rpx; }
.recruit-cell { flex: 1; background: #F7F6F2; border-radius: 20rpx; padding: 24rpx; text-align: center; }
.rc-num { font-size: 40rpx; font-weight: 800; color: #B8860B; display: block; }
.rc-dur { font-size: 28rpx; font-weight: 700; color: #1A1A1A; display: block; }
.rc-lbl { font-size: 22rpx; color: #8A8A8A; display: block; margin-top: 4rpx; }

.detail-section { margin-bottom: 32rpx; }
.ds-title { font-size: 28rpx; font-weight: 700; color: #1A1A1A; margin-bottom: 16rpx; display: block; }
.ds-body { font-size: 28rpx; color: #4A4A4A; line-height: 1.8; display: block; }
.ds-body.clamped { max-height: 160rpx; overflow: hidden; position: relative; }
.ds-body.clamped::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 60rpx; background: linear-gradient(transparent, #fff); }
.expand-btn { display: inline-block; margin-top: 12rpx; font-size: 24rpx; color: #5A6B3A; font-weight: 500; padding: 4rpx 0; }
.ds-body.link { color: #007aff; }
.contact-box { background: #F7F6F2; border-radius: 16rpx; padding: 20rpx; margin-top: 16rpx; font-size: 26rpx; color: #6B6B6B; }

.tags-row { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag { background: #F7F6F2; color: #4A4A4A; padding: 10rpx 28rpx; border-radius: 999px; font-size: 24rpx; font-weight: 500; }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 16rpx 32rpx 48rpx; display: flex; gap: 20rpx; border-radius: 32rpx 32rpx 0 0; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06); z-index: 10; }
.action-btn { flex: 1; text-align: center; padding: 28rpx 0; border-radius: 999px; font-size: 30rpx; font-weight: 600; }
.vote-btn.not-voted { background: #F7F6F2; color: #1A1A1A; }
.vote-btn.voted { background: #5A6B3A; color: #fff; }
.contact-btn { background: #B8860B; color: #fff; }

.owner-actions { display: flex; gap: 20rpx; margin: 24rpx; }
.owner-btn { flex: 1; text-align: center; padding: 24rpx 0; border-radius: 20rpx; font-size: 28rpx; font-weight: 500; }
.owner-btn.edit { background: #F5F8FF; color: #007aff; border: 1rpx solid rgba(0,122,255,0.2); }
.owner-btn.delete { background: #FEF2F2; color: #DC2626; }

.poster-action { text-align: center; padding: 20rpx; margin: 24rpx; font-size: 24rpx; color: #B8860B; border: 1rpx solid #F5E6B8; border-radius: 16rpx; background: #FFF8E1; }
.report-action { text-align: center; padding: 20rpx; margin: 24rpx; font-size: 24rpx; color: #9CA3AF; border: 1rpx solid #E5E5EA; border-radius: 16rpx; }
