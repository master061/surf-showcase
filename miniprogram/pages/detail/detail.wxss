.detail-wrap{padding:0 0 24px}
.detail-header{margin-bottom:-20px}
.detail-thumb{display:block;height:200px;background:linear-gradient(135deg,#667eea,#764ba2);line-height:200px;text-align:center;font-size:56px}
.detail-body{padding:0 16px;position:relative;z-index:2}
.detail-main{background:#fff;border-radius:20px;padding:20px;box-shadow:0 4px 20px rgba(0,0,0,0.06)}
.badges-row{display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap}
.detail-title{font-size:22px;font-weight:800;color:#1d1d1f;line-height:1.3;margin-bottom:14px;display:block}
.author-row{display:flex;align-items:center;gap:12px;padding:12px 14px;background:#f5f5f7;border-radius:14px;margin-bottom:16px}
.author-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;color:#fff;font-size:20px;font-weight:700;text-align:center;line-height:44px}
.author-info{flex:1}
.author-name{font-size:15px;font-weight:600;color:#1d1d1f;display:block}
.author-school{font-size:12px;color:#86868b}
.vote-box{text-align:center}
.vote-num{font-size:18px;font-weight:800;color:#f59e0b;display:block}
.vote-lbl{font-size:10px;color:#86868b}
.recruit-banner{background:#fffbeb;border:1px solid #fde68a;border-radius:12px;padding:12px;margin-bottom:16px;font-size:13px;color:#92400e}
.recruit-grid{display:flex;gap:10px;margin-bottom:16px}
.recruit-cell{flex:1;background:#f5f5f7;border-radius:12px;padding:12px;text-align:center}
.rc-num{font-size:20px;font-weight:800;color:#d97706;display:block}
.rc-dur{font-size:14px;font-weight:700;color:#1d1d1f;display:block}
.rc-lbl{font-size:11px;color:#86868b;display:block;margin-top:2px}
.detail-section{margin-bottom:16px}
.ds-title{font-size:15px;font-weight:700;color:#1d1d1f;margin-bottom:8px;display:block}
.ds-body{font-size:14px;color:#515154;line-height:1.8;display:block}
.ds-body.clamped{max-height:100px;overflow:hidden;position:relative}
.ds-body.clamped::after{content:'';position:absolute;bottom:0;left:0;right:0;height:30px;background:linear-gradient(transparent,#fff)}
.expand-btn{display:inline-block;margin-top:6px;font-size:12px;color:#007aff;font-weight:500;padding:2px 0}
.ds-body.link{color:#007aff}
.contact-box{background:#f5f5f7;border-radius:8px;padding:10px;margin-top:8px;font-size:13px;color:#6b7280}
.tags-row{display:flex;flex-wrap:wrap;gap:6px}
.tag{background:#f5f5f7;color:#515154;padding:5px 14px;border-radius:100px;font-size:12px;font-weight:500}
.action-row-detail{display:flex;gap:10px;margin-top:4px}
.vote-btn{flex:1;text-align:center;padding:14px 0;border-radius:14px;font-size:15px;font-weight:600}
.vote-btn.not-voted{background:#f5f5f7;color:#515154}
.vote-btn.voted{background:#007aff;color:#fff;box-shadow:0 4px 12px rgba(0,122,255,0.3)}
.contact-btn{flex:1;text-align:center;padding:14px 0;border-radius:14px;font-size:15px;font-weight:600;background:#d97706;color:#fff}
.owner-actions{display:flex;gap:10px;margin-top:14px}
.owner-btn{flex:1;text-align:center;padding:12px 0;border-radius:12px;font-size:14px;font-weight:500}
.owner-btn.edit{background:#f5f8ff;color:#007aff;border:1px solid rgba(0,122,255,0.2)}
.owner-btn.delete{background:#fef2f2;color:#dc2626}
.report-action{text-align:center;padding:10px;margin-top:8px;font-size:12px;color:#9ca3af;border:1px solid #e5e5ea;border-radius:10px}

