<view class="create-wrap">
  <!-- Step indicator -->
  <view class="step-indicator">
    <view class="step-dot {{step>=1?'active':''}}"><text class="step-num">1</text><text class="step-lbl">项目内容</text></view>
    <view class="step-line {{step>=2?'active':''}}"></view>
    <view class="step-dot {{step>=2?'active':''}}"><text class="step-num">2</text><text class="step-lbl">联系方式</text></view>
    <view class="step-line {{step>=3?'active':''}}"></view>
    <view class="step-dot {{step>=3?'active':''}}"><text class="step-num">3</text><text class="step-lbl">预览提交</text></view>
  </view>

  <view class="form-group" wx:if="{{error}}"><view class="error-msg">{{error}}</view></view>

  <!-- ====== Step 1: Content ====== -->
  <block wx:if="{{step===1}}">
    <view class="create-card">
      <text class="section-title">📝 基本信息</text>

      <view class="form-group"><text class="form-label">项目名称 *</text><input class="form-input" value="{{title}}" bindinput="onInput" data-field="title" placeholder="输入项目名称"/></view>
      <view class="form-row">
        <view class="form-group" style="flex:1"><text class="form-label">研究领域 *</text><picker mode="selector" range="{{fields}}" value="{{field}}" bindchange="onFieldChange"><view class="form-input">{{fields[field]}}</view></picker></view>
        <view class="form-group" style="flex:1"><text class="form-label">项目类型 *</text><picker mode="selector" range="{{types}}" value="{{type}}" bindchange="onTypeChange"><view class="form-input">{{types[type]}}</view></picker></view>
      </view>
      <view class="form-row">
        <view class="form-group" style="flex:1"><text class="form-label">姓名</text><input class="form-input" value="{{studentName}}" bindinput="onInput" data-field="studentName"/></view>
        <view class="form-group" style="flex:1"><text class="form-label">学校/院系</text><input class="form-input" value="{{institution}}" bindinput="onInput" data-field="institution"/></view>
      </view>
      <view class="form-row">
        <view class="form-group" style="flex:1"><text class="form-label">指导老师</text><input class="form-input" value="{{advisor}}" bindinput="onInput" data-field="advisor" placeholder="刘教授"/></view>
        <view class="form-group" style="flex:1"><text class="form-label">项目年份</text><picker mode="selector" range="{{years}}" value="{{year}}" bindchange="onYearChange"><view class="form-input">{{years[year]}}</view></picker></view>
      </view>

      <!-- 团队成员（仅团队项目时显示） -->
      <view class="form-group" wx:if="{{typeValues[type]==='TEAM'}}">
        <text class="form-label">项目成员</text>
        <input class="form-input" value="{{members}}" bindinput="onInput" data-field="members" placeholder="张明、李华、王雪"/>
      </view>

      <text class="section-title" style="margin-top:20px">📋 项目状态</text>
      <view class="status-toggle">
        <view class="st-opt {{status==='COMPLETED'?'active done':''}}" data-value="COMPLETED" bindtap="toggleStatus">✅ 已完成</view>
        <view class="st-opt {{status==='RECRUITING'?'active recruit':''}}" data-value="RECRUITING" bindtap="toggleStatus">🔍 招人中</view>
      </view>

      <text class="section-title" style="margin-top:20px">📄 项目内容</text>

      <view class="form-group"><text class="form-label">项目简介 *</text><textarea class="form-input form-textarea" value="{{abstract}}" bindinput="onInput" data-field="abstract" placeholder="简要介绍你的项目..." style="min-height:80px"/></view>
      <view class="form-group"><text class="form-label">研究成果</text><textarea class="form-input form-textarea" value="{{content}}" bindinput="onInput" data-field="content" placeholder="项目的研究成果、方法、数据等..." style="min-height:120px"/></view>
      <view class="form-group"><text class="form-label">标签（逗号分隔）</text><input class="form-input" value="{{tags}}" bindinput="onInput" data-field="tags" placeholder="例如：机器学习, 计算机视觉"/></view>
      <view class="form-group"><text class="form-label">封面图</text><view class="thumb-picker" bindtap="pickThumb"><image class="thumb-preview" src="{{thumbnail}}" mode="aspectFill" wx:if="{{thumbnail}}"/><view class="thumb-placeholder" wx:else><text class="thumb-icon">📷</text><text class="thumb-text">点击选择封面图</text></view></view></view>

      <button class="btn btn-primary btn-block" bindtap="nextStep">下一步 →</button>
    </view>
  </block>

  <!-- ====== Step 2: Contact ====== -->
  <block wx:if="{{step===2}}">
    <view class="create-card">
      <text class="section-title">📞 联系方式</text>
      <view class="form-group"><text class="form-label">联系方式 *</text><input class="form-input" value="{{contactInfo}}" bindinput="onInput" data-field="contactInfo" placeholder="邮箱或微信"/></view>
      <view class="form-group"><text class="form-label">项目地址</text><input class="form-input" value="{{projectUrl}}" bindinput="onInput" data-field="projectUrl" placeholder="GitHub 等项目地址"/></view>

      <view wx:if="{{!isRecruit}}">
        <view class="form-group"><text class="form-label">成果链接</text><input class="form-input" value="{{resultLinks}}" bindinput="onInput" data-field="resultLinks" placeholder="论文或演示链接"/></view>
      </view>
      <view wx:if="{{isRecruit}}">
        <view class="form-row">
          <view class="form-group" style="flex:1"><text class="form-label">招募人数</text><picker mode="selector" range="{{recruitCountOpts}}" value="{{recruitCount-1}}" bindchange="onRecruitCountChange"><view class="form-input">{{recruitCount?recruitCount+'人':'选择人数'}}</view></picker></view>
          <view class="form-group" style="flex:1"><text class="form-label">预期周期</text><picker mode="selector" range="{{durationOpts}}" bindchange="onDurationChange"><view class="form-input">{{expectedDuration||'选择周期'}}</view></picker></view>
        </view>
        <view class="form-group"><text class="form-label">招募要求</text><textarea class="form-input form-textarea" value="{{recruitRequirements}}" bindinput="onInput" data-field="recruitRequirements" placeholder="描述需要的技能、经验要求..." style="min-height:60px"/></view>
      </view>

      <view class="btn-row"><button class="btn btn-outline" bindtap="prevStep">← 上一步</button><button class="btn btn-primary" bindtap="nextStep" style="flex:1">下一步 →</button></view>
    </view>
  </block>

  <!-- ====== Step 3: Preview ====== -->
  <block wx:if="{{step===3}}">
    <view class="create-card">
      <text class="section-title">👀 预览项目</text>
      <view class="preview-section"><text class="preview-label">项目名称</text><text class="preview-value">{{title}}</text></view>
      <view class="preview-section"><text class="preview-label">领域</text><text class="preview-value">{{fields[field]}}</text></view>
      <view class="preview-section"><text class="preview-label">类型</text><text class="preview-value">{{types[type]}}</text></view>
      <view class="preview-section" wx:if="{{advisor}}"><text class="preview-label">指导老师</text><text class="preview-value">{{advisor}}</text></view>
      <view class="preview-section" wx:if="{{members}}"><text class="preview-label">项目成员</text><text class="preview-value">{{members}}</text></view>
      <view class="preview-section"><text class="preview-label">项目简介</text><text class="preview-value">{{abstract}}</text></view>
      <view class="preview-section" wx:if="{{content}}"><text class="preview-label">研究成果</text><text class="preview-value">{{content}}</text></view>
      <view class="preview-section"><text class="preview-label">联系方式</text><text class="preview-value">{{contactInfo}}</text></view>
      <view class="preview-section" wx:if="{{projectUrl}}"><text class="preview-label">项目地址</text><text class="preview-value">{{projectUrl}}</text></view>
      <view class="preview-section"><text class="preview-label">状态</text><text class="preview-value">{{isRecruit?'🔍 招人中':'✅ 已完成'}}</text></view>

      <view class="btn-row"><button class="btn btn-outline" bindtap="prevStep">← 上一步</button><button class="btn btn-primary" bindtap="submitAndReview" loading="{{loading}}" style="flex:1">提交审核</button></view>
    </view>
  </block>
</view>
