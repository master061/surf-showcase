.pg { background: #F7F6F2; min-height: 100vh; padding-bottom: 120rpx; }
.serif { font-family: Georgia, 'Times New Roman', 'Songti SC', serif; font-weight: 600; letter-spacing: -0.02em; }

.header { padding: 48rpx 32rpx 24rpx; }
.title-xl { font-size: 48rpx; color: #1A1A1A; }
.search-box { margin-top: 24rpx; background: #EFEEE9; border-radius: 999px; padding: 20rpx 32rpx; }
.search-box input { font-size: 28rpx; color: #1A1A1A; }
.placeholder { color: #8A8A8A; }

.chips { white-space: nowrap; padding: 12rpx 32rpx 24rpx; }
.chip { display: inline-block; padding: 12rpx 32rpx; border-radius: 999px; font-size: 26rpx; margin-right: 16rpx; background: #EFEEE9; color: #4A4A4A; transition: all 0.15s; }
.chip.active { background: #1A1A1A; color: #fff; }

.section { padding: 0 32rpx; }
.sec-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.sec-title { font-size: 40rpx; color: #1A1A1A; }
.sec-more { font-size: 26rpx; color: #6B6B6B; }

.project-card { background: #fff; border-radius: 32rpx; overflow: hidden; margin-bottom: 32rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.cover { width: 100%; height: 320rpx; display: block; }
.card-body { padding: 28rpx; }
.badges { display: flex; gap: 12rpx; margin-bottom: 16rpx; flex-wrap: wrap; }
.title { font-size: 32rpx; font-weight: 700; color: #1A1A1A; margin-bottom: 8rpx; display: block; line-height: 1.3; }
.meta { font-size: 24rpx; color: #8A8A8A; display: block; }
.card-footer { margin-top: 16rpx; display: flex; justify-content: flex-end; }
.vote-pill { display: inline-flex; align-items: center; gap: 4rpx; background: #F7F6F2; padding: 8rpx 20rpx; border-radius: 999px; font-size: 24rpx; font-weight: 600; color: #1A1A1A; }
