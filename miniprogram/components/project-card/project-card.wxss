.card {
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-cover { width: 100%; height: 280rpx; display: block; }
.card-body { padding: 24rpx; }
.badges-row { display: flex; gap: 10rpx; margin-bottom: 14rpx; flex-wrap: wrap; align-items: center; }
.badge { display: inline-flex; align-items: center; justify-content: center; padding: 0 20rpx; border-radius: 999px; font-size: 22rpx; font-weight: 600; height: 48rpx; line-height: 48rpx; box-sizing: border-box; border: 1rpx solid transparent; }
.badge-done { background: #E8EDDE; color: #5A6B3A; }
.badge-recruit { background: #FFF8E1; color: #B8860B; border: 1rpx solid #F5E6B8; }
.badge-blue { background: #E6F4F7; color: #2AAECF; }
.badge-gray { background: #F2F2F0; color: #6B6B6B; }
.badge-green { background: #E8EDDE; color: #5A6B3A; }
.card-title { font-size: 30rpx; font-weight: 700; color: #1A1A1A; line-height: 1.3; margin-bottom: 8rpx; display: block; }
.card-abs { font-size: 26rpx; color: #6B6B6B; line-height: 1.5; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; margin-bottom: 16rpx; }
.card-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 16rpx; }
.tag { background: #F7F6F2; color: #4A4A4A; padding: 6rpx 18rpx; border-radius: 999px; font-size: 22rpx; font-weight: 500; }
.tag-recruit { background: #FFF8E1; color: #B8860B; font-weight: 600; }
.card-footer { display: flex; align-items: center; gap: 14rpx; padding-top: 16rpx; border-top: 1rpx solid #F2F2F0; }
.avatar { width: 40rpx; height: 40rpx; border-radius: 50%; background: linear-gradient(135deg,#667eea,#764ba2); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 20rpx; font-weight: 700; flex-shrink: 0; text-align: center; line-height: 40rpx; }
.author { font-size: 24rpx; color: #8A8A8A; flex: 1; }
.vote-pill { display: inline-flex; align-items: center; gap: 4rpx; background: #F7F6F2; padding: 8rpx 20rpx; border-radius: 999px; font-size: 22rpx; font-weight: 600; color: #1A1A1A; }
