.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  border-radius: 24px 24px 0 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.08);
  z-index: 999;
}
.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
}
.tab-icon {
  width: 48rpx;
  height: 48rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}
.tab-text {
  font-size: 20rpx;
  color: #8A8A8A;
}
.active .tab-text {
  color: #1A1A1A;
  font-weight: 600;
}

