<view class="tab-bar">
  <view class="tab-bar-item {{selected === index ? 'active' : ''}}"
    wx:for="{{list}}" wx:key="index"
    data-path="{{item.pagePath}}" data-index="{{index}}"
    bindtap="switchTab">
    <view class="tab-icon icon-{{item.icon}}"></view>
    <view class="tab-text">{{item.text}}</view>
  </view>
</view>
