page{background:#f3f4f6;box-sizing:border-box;color:#111827;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif}.card{background:#fff;border-radius:12rpx;box-shadow:0 1rpx 2rpx rgba(0,0,0,.04),0 4rpx 12rpx rgba(0,0,0,.04);padding:16rpx;transition:transform .15s,box-shadow .15s}.card-clickable:active{box-shadow:0 2rpx 4rpx rgba(0,0,0,.06),0 8rpx 20rpx rgba(0,0,0,.08);transform:scale(.985)}.badge{border-radius:100rpx;display:inline-block;font-size:11rpx;font-weight:500;padding:2rpx 8rpx}.badge-blue{background:#eff6ff;color:#1d4ed8}.badge-green{background:#f0fdf4;color:#15803d}.badge-gray{background:#f3f4f6;color:#6b7280}.badge-yellow{background:#fefce8;color:#a16207}.badge-orange{background:#fff7ed;color:#ea580c}.badge-purple{background:#f5f3ff;color:#7c3aed}.btn{align-items:center;border:none;border-radius:10rpx;display:inline-flex;font-size:14rpx;font-weight:500;justify-content:center;padding:10rpx 20rpx;transition:all .15s}.btn-primary{background:linear-gradient(135deg,#1e40af,#1d4ed8);box-shadow:0 2rpx 8rpx rgba(30,64,175,.25);color:#fff}.btn-primary:active{opacity:.9;transform:scale(.97)}.btn-outline{background:transparent;border:1rpx solid #d1d5db;color:#374151}.btn-outline:active{background:#f9fafb;transform:scale(.97)}.btn-danger{background:#fef2f2;border:1rpx solid #fecaca;color:#dc2626}.btn-danger:active{background:#fee2e2;transform:scale(.97)}.btn-block{width:100%}.btn-sm{border-radius:8rpx;font-size:12rpx;padding:6rpx 12rpx}.btn-xs{border-radius:6rpx;font-size:11rpx;padding:4rpx 8rpx}.btn-outline.active{background:#eff6ff;border-color:#1e40af;color:#1e40af}.input-group{margin-bottom:14rpx}.input-label{color:#374151;display:block;font-size:13rpx;font-weight:500;margin-bottom:6rpx}.input-label .required{color:#dc2626;margin-left:2rpx}.input{background:#fff;border:1rpx solid #e5e7eb;border-radius:8rpx;box-sizing:border-box;font-size:14rpx;padding:10rpx 12rpx;transition:border-color .2s,box-shadow .2s;width:100%}.input:focus{border-color:#1e40af;box-shadow:0 0 0 3rpx rgba(30,64,175,.1);outline:none}.input:disabled{background:#f9fafb;color:#9ca3af}.textarea{background:#fff;border:1rpx solid #e5e7eb;border-radius:8rpx;box-sizing:border-box;font-size:14rpx;line-height:1.6;padding:10rpx 12rpx;resize:vertical;transition:border-color .2s,box-shadow .2s;width:100%}.textarea:focus{border-color:#1e40af;box-shadow:0 0 0 3rpx rgba(30,64,175,.1);outline:none}.picker-input{background:#fff;border:1rpx solid #e5e7eb;border-radius:8rpx;box-sizing:border-box;color:#111827;font-size:14rpx;padding:10rpx 12rpx;width:100%}.skeleton{animation:shimmer 1.5s infinite;background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%}@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}.empty-state{align-items:center;display:flex;flex-direction:column;justify-content:center;padding:48rpx 24rpx}.empty-state-icon{font-size:48rpx;margin-bottom:12rpx}.empty-state-text{color:#9ca3af;font-size:14rpx;margin-bottom:16rpx}.divider{background:#e5e7eb;height:1rpx;margin:16rpx 0}.divider-light{background:#f3f4f6;height:1rpx;margin:12rpx 0}.section-header{align-items:center;display:flex;justify-content:space-between;margin-bottom:12rpx}.section-title{color:#111827;font-size:16rpx;font-weight:600}.sticky-bottom{background:#fff;border-top:1rpx solid #f3f4f6;bottom:0;box-shadow:0 -2rpx 8rpx rgba(0,0,0,.04);padding:12rpx 16rpx;position:sticky;z-index:10}.tag-chip{align-items:center;background:#eff6ff;border-radius:100rpx;color:#1d4ed8;display:inline-flex;font-size:12rpx;gap:4rpx;padding:4rpx 10rpx}.tag-chip-remove{align-items:center;background:#bfdbfe;border-radius:7rpx;color:#1d4ed8;display:inline-flex;font-size:10rpx;height:14rpx;justify-content:center;line-height:1;width:14rpx}.flex{display:flex}.flex-col{flex-direction:column}.items-center{align-items:center}.justify-center{justify-content:center}.justify-between{justify-content:space-between}.flex-wrap{flex-wrap:wrap}.gap-1{gap:4rpx}.gap-2{gap:8rpx}.gap-3{gap:12rpx}.gap-4{gap:16rpx}.flex-1{flex:1}.min-w-0{min-width:0}.shrink-0{flex-shrink:0}.text-center{text-align:center}.line-clamp-2{display:-webkit-box;-webkit-line-clamp:2;overflow:hidden;text-overflow:ellipsis;-webkit-box-orient:vertical}@keyframes heartBeat{0%{transform:scale(1)}25%{transform:scale(1.3)}50%{transform:scale(1)}75%{transform:scale(1.3)}100%{transform:scale(1)}}.heart-beat{animation:heartBeat .6s ease-in-out}@keyframes fadeInUp{from{opacity:0;transform:translateY(12rpx)}to{opacity:1;transform:translateY(0)}}@keyframes fadeIn{from{opacity:0}to{opacity:1}}@keyframes slideInRight{from{opacity:0;transform:translateX(20rpx)}to{opacity:1;transform:translateX(0)}}.page-enter{animation:fadeInUp .3s ease-out both}.card-stagger:nth-child(1){animation:fadeInUp .35s ease-out both;animation-delay:.05s}.card-stagger:nth-child(2){animation:fadeInUp .35s ease-out both;animation-delay:.1s}.card-stagger:nth-child(3){animation:fadeInUp .35s ease-out both;animation-delay:.15s}.card-stagger:nth-child(4){animation:fadeInUp .35s ease-out both;animation-delay:.2s}.card-stagger:nth-child(5){animation:fadeInUp .35s ease-out both;animation-delay:.25s}.card-stagger:nth-child(n+6){animation:fadeInUp .35s ease-out both;animation-delay:.3s}.hero-fade-1{animation:fadeInUp .4s ease-out both}.hero-fade-2{animation:fadeInUp .4s ease-out .1s both}.hero-fade-3{animation:fadeInUp .4s ease-out .2s both}.hero-fade-4{animation:fadeInUp .4s ease-out .3s both}@keyframes pulse{0%,100%{opacity:1}50%{opacity:.7}}.pulse{animation:pulse 2s ease-in-out infinite}